rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: vocabulary
    // Fields:
    //   - userId: string (required)
    //   - word: string (required)
    //   - definition: string (required)
    //   - usage: string (optional)
    //   - examples: list (optional)
    //   - createdAt: timestamp (required)
    //   - masteryLevel: number (optional)
    //
    // Collection: speakingSessions
    // Fields:
    //   - userId: string (required)
    //   - type: string (required, enum: ['echo', 'roleplay'])
    //   - topic: string (optional)
    //   - score: number (optional)
    //   - feedback: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidVocabulary(data) {
      return data.userId is string &&
             data.word is string && data.word.size() > 0 && data.word.size() < 200 &&
             data.definition is string && data.definition.size() < 2000;
    }

    function isValidSession(data) {
      return data.userId is string &&
             data.type in ['echo', 'roleplay'] &&
             (!('score' in data) || (data.score is number && data.score >= 0 && data.score <= 100));
    }

    match /vocabulary/{wordId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && isValidVocabulary(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId) && isValidVocabulary(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }

    match /speakingSessions/{sessionId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && isValidSession(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
